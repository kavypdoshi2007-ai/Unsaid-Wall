// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  coach
  admin
}

enum EmotionType {
  ANXIOUS
  SAD
  ANGRY
  LONELY
  OVERWHELMED
  HOPEFUL
  NUMB
  CONFUSED
}

enum IntensityLevel {
  low
  med
  high
}

enum LanguageCode {
  en
  hi
  gu
}

enum FlagLevel {
  safe
  concerning
  crisis
}

enum ReactionType {
  HEAR_YOU      
  NOT_ALONE     
  STRENGTH      
  WILL_PASS
}

enum SessionStatus {
  pending
  active
  completed
  declined
}

enum AvailabilityStatus {
  available
  busy
  away
}

enum MessageType {
  text
  resource
}

// ==========================================
// MODELS (Database Tables)
// ==========================================
model PhoneOtpVerification {
  id                String   @id @default(uuid()) @db.Uuid
  phone_number      String   @unique
  password_hash     String
  display_name_pool String[]
  otp_code          String
  expires_at        DateTime
  created_at        DateTime @default(now())
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  phone_number      String            @unique
  password_hash     String
  display_name_pool String[]          
  role              UserRole          @default(user)
  is_verified       Boolean           @default(false)
  is_banned         Boolean           @default(false)
  created_at        DateTime          @default(now())

  // Relations
  posts             Post[]
  reactions         Reaction[]
  coach_profile     Coach?            
  user_sessions     Session[]         @relation("UserSessions")
  messages_sent     Message[]
  journal_entries   EmotionJournal[]
  announcements     Announcement[]
  resources_created Resource[]
}

model Post {
  id           String         @id @default(uuid()) @db.Uuid
  user_id      String         @db.Uuid
  content      String         @db.VarChar(280) // Constrained character limit
  display_name String
  emotion      EmotionType
  intensity    IntensityLevel
  language     LanguageCode
  is_flagged   Boolean        @default(false)
  flag_level   FlagLevel      @default(safe)
  is_hidden    Boolean        @default(false)
  created_at   DateTime       @default(now())

  // Relations
  user         User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reactions    Reaction[]
  journals     EmotionJournal[]
}

model Reaction {
  id            String       @id @default(uuid()) @db.Uuid
  post_id       String       @db.Uuid
  user_id       String       @db.Uuid
  reaction_type ReactionType
  
  // Relations
  post          Post         @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Composite Unique constraint (Prevents a user from reacting multiple times to the same post)
  @@unique([post_id, user_id])
}

model Coach {
  id              String             @id @default(uuid()) @db.Uuid
  user_id         String             @unique @db.Uuid // Must be unique for 1-to-1 matching
  name            String?            
  bio             String             @db.VarChar(200)
  specializations String[]
  languages       String[]
  availability    AvailabilityStatus @default(available)
  rating          Decimal            @db.Decimal(3, 2) @default(0.0) // Handled as exact decimal (e.g., 4.75)
  sessions_count  Int                @default(0)
  invite_token    String?

  // Relations
  user            User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  coach_sessions  Session[]          @relation("CoachSessions")
}

model Session {
  id              String        @id @default(uuid()) @db.Uuid
  user_id         String        @db.Uuid
  coach_id        String?        @db.Uuid
  status          SessionStatus @default(pending)
  context_message String?       // Optional
  rating          Int?          // Nullable (1-5 range logic handled at app level)
  coach_notes     String?       @default("") // Private notes field
  started_at      DateTime      @default(now())
  ended_at        DateTime?     // Nullable until completed

  // Relations
  user            User          @relation("UserSessions", fields: [user_id], references: [id], onDelete: Cascade)
  coach           Coach?         @relation("CoachSessions", fields: [coach_id], references: [id], onDelete: Cascade)
  messages        Message[]
}

model Message {
  id           String      @id @default(uuid()) @db.Uuid
  session_id   String      @db.Uuid
  sender_id    String      @db.Uuid
  content      String
  message_type MessageType @default(text)
  created_at   DateTime    @default(now())

  // Relations
  session      Session     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  sender       User        @relation(fields: [sender_id], references: [id], onDelete: Cascade)
}

model EmotionJournal {
  id         String         @id @default(uuid()) @db.Uuid
  user_id    String         @db.Uuid
  emotion    EmotionType
  intensity  IntensityLevel
  post_id    String?        @db.Uuid // Nullable connection to peer posts
  note       String?        // Private optional textual addition
  created_at DateTime       @default(now())

  // Relations
  user       User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post       Post?          @relation(fields: [post_id], references: [id], onDelete: SetNull)
}

model Announcement {
  id         String   @id @default(uuid()) @db.Uuid
  admin_id   String   @db.Uuid
  content    String
  link       String?
  is_pinned  Boolean  @default(false)
  expires_at DateTime?
  created_at DateTime @default(now())

  // Relations
  admin      User     @relation(fields: [admin_id], references: [id], onDelete: Cascade)
}

model Resource {
  id           String    @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  type         String    // "link" or "text"
  url          String?   // Optional URL for links
  content      String?   // Optional long text field 
  category     String    // Matches your frontend category filter pills
  is_pinned    Boolean   @default(false)
  created_at   DateTime  @default(now())
  
  // Track who uploaded it (Admin or Coach)
  creator_id   String    @db.Uuid
  creator      User      @relation(fields: [creator_id], references: [id], onDelete: Cascade)
}